{# the-sealed-envelope.njk — Private letter, A5 portrait, 1–3 pages
   Data: { session, host, reflection, stats{accuracy, mostSuspected, biggestSurprise} }
#}
{% extends "../_base.njk" %}
{% import "../_macros.njk" as m %}

{% set theme = "personal-letter" %}
{% set title = "The Sealed Envelope — " + session.title %}

{% block extraStyles %}
{{ m.macroStyles() }}
<style>
  .envelope-page {
    padding: 24mm 22mm 18mm 22mm;
    min-height: 210mm;
    background-color: var(--color-bg);
    line-height: var(--lh-letter);
  }
  .for-eyes-only {
    text-align: center;
    font-family: var(--ff-heading);
    font-size: var(--fs-lg);
    color: var(--color-accent);
    margin: var(--sp-4) 0 var(--sp-8);
    font-style: italic;
  }
  .reflection-body {
    margin-bottom: var(--sp-8);
    padding: var(--sp-4);
    border-left: 2px solid var(--color-gold);
    line-height: var(--lh-letter);
  }
  .stats-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    justify-content: center;
    margin: var(--sp-6) 0;
  }
  .stat-block {
    flex: 1;
    min-width: 120px;
    max-width: 160px;
    padding: var(--sp-4);
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-md);
    text-align: center;
    background-color: var(--color-highlight);
  }
  .stat-block__value {
    font-family: var(--ff-heading);
    font-size: var(--fs-xl);
    color: var(--color-accent);
    display: block;
    margin-bottom: var(--sp-1);
  }
  .stat-block__label {
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }
  .signoff {
    margin-top: var(--sp-8);
    text-align: right;
    font-style: italic;
    color: var(--color-muted);
  }
  .signoff__tagline {
    margin-top: var(--sp-4);
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
{% endblock %}

{% block content %}
<div class="envelope-page texture-aged">
  <div style="position: relative; z-index: 2;">
    {# ── WAX SEAL ── #}
    {{ m.waxSeal('E.E.') }}

    {# ── HEADING ── #}
    <p class="for-eyes-only">For the Host's Eyes Only</p>

    {{ m.divider() }}

    {# ── HOST GREETING ── #}
    <p>Dear {{ host.name }},</p>
    <p>
      Thank you for orchestrating tonight's intrigue. What follows is a private
      record of the evening — your reflection, preserved alongside the numbers
      that tell their own story.
    </p>

    {{ m.ornament('dots') }}

    {# ── HOST REFLECTION ── #}
    <h3>Your Reflection</h3>
    <div class="reflection-body">
      <p>{{ reflection }}</p>
    </div>

    {{ m.divider('◆') }}

    {# ── SESSION STATISTICS ── #}
    <h3 style="text-align: center;">The Evening in Numbers</h3>

    <div class="stats-grid">
      {% if stats.accuracy is defined %}
      <div class="stat-block avoid-break">
        <span class="stat-block__value">{{ stats.accuracy }}%</span>
        <span class="stat-block__label">Guess Accuracy</span>
      </div>
      {% endif %}

      {% if stats.mostSuspected %}
      <div class="stat-block avoid-break">
        <span class="stat-block__value" style="font-size: var(--fs-md);">{{ stats.mostSuspected }}</span>
        <span class="stat-block__label">Most Suspected</span>
      </div>
      {% endif %}

      {% if stats.biggestSurprise %}
      <div class="stat-block avoid-break">
        <span class="stat-block__value" style="font-size: var(--fs-md);">{{ stats.biggestSurprise }}</span>
        <span class="stat-block__label">Biggest Surprise</span>
      </div>
      {% endif %}

      {% if stats.totalClues is defined %}
      <div class="stat-block avoid-break">
        <span class="stat-block__value">{{ stats.totalClues }}</span>
        <span class="stat-block__label">Clues Found</span>
      </div>
      {% endif %}

      {% if stats.totalPlayers is defined %}
      <div class="stat-block avoid-break">
        <span class="stat-block__value">{{ stats.totalPlayers }}</span>
        <span class="stat-block__label">Suspects</span>
      </div>
      {% endif %}
    </div>

    {{ m.ornament('dots') }}

    {# ── SIGN-OFF ── #}
    <div class="signoff">
      <p>Until the next crime&hellip;</p>
      <p style="margin-top: var(--sp-2);">The Ephemera Engine</p>
      <p class="signoff__tagline">Every game leaves a trace</p>
    </div>
  </div>
</div>
{% endblock %}
