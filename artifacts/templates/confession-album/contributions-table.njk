{# contributions-table.njk — Single page or 2-page spread, A5 landscape
   Data: { session, players[], questions[], answers[], completionMatrix }
#}
{% extends "../_base.njk" %}
{% import "../_macros.njk" as m %}

{% set theme = "confession-album" %}
{% set title = "Contributions — " + session.title %}

{% block extraStyles %}
{{ m.macroStyles() }}
<style>
  .contributions-page {
    padding: 14mm 18mm;
  }
  .contributions-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--sp-6);
  }
  .contributions-header__title {
    font-family: var(--ff-heading);
    font-size: var(--fs-xl);
    color: var(--color-accent);
  }
  .contributions-header__meta {
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    color: var(--color-muted);
  }
  .contributions-table {
    width: 100%;
    font-size: var(--fs-xs);
    border: 1px solid var(--color-divider);
  }
  .contributions-table th {
    font-size: var(--fs-xs);
    padding: var(--sp-1) var(--sp-2);
    background-color: var(--color-highlight);
    white-space: nowrap;
    max-width: 80px;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .contributions-table th.player-col {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    height: 60px;
    text-align: left;
    padding: var(--sp-2) var(--sp-1);
  }
  .contributions-table td {
    padding: var(--sp-1) var(--sp-2);
    font-size: 9px;
    max-width: 100px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .contributions-table td.question-cell {
    font-family: var(--ff-body);
    font-weight: 700;
    font-size: var(--fs-xs);
    white-space: normal;
    max-width: 120px;
  }
  .cell-check {
    text-align: center;
    color: var(--color-accent);
    font-size: var(--fs-sm);
  }
  .cell-empty {
    text-align: center;
    color: var(--color-divider);
  }
  .cell-preview {
    color: var(--color-muted);
    font-style: italic;
  }
  .legend {
    margin-top: var(--sp-4);
    display: flex;
    gap: var(--sp-6);
    font-size: var(--fs-xs);
    color: var(--color-muted);
  }
  .legend__item {
    display: flex;
    align-items: center;
    gap: var(--sp-1);
  }
  .legend__swatch {
    width: 12px;
    height: 12px;
    border: 1px solid var(--color-divider);
    display: inline-block;
  }
  .legend__swatch--completed { background-color: var(--color-accent); opacity: 0.2; }
  .legend__swatch--empty { background-color: var(--color-bg); }
</style>
{% endblock %}

{% block content %}
<div class="contributions-page page--landscape texture-parchment">
  <div style="position: relative; z-index: 2;">
    <div class="contributions-header">
      <h1 class="contributions-header__title">Contributions</h1>
      <span class="contributions-header__meta">
        {{ session.title }} &middot; {{ session.date | dateFormat }}
      </span>
    </div>

    <div class="table-container">
      <table class="contributions-table">
        <thead>
          <tr>
            <th>Question</th>
            {% for player in players %}
            <th class="player-col">{{ player.name }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for question in questions %}
          <tr>
            <td class="question-cell">{{ question.text | truncate(50) }}</td>
            {% for player in players %}
              {% set answered = false %}
              {% set answerText = "" %}
              {% for answer in answers %}
                {% if answer.questionId == question.id and answer.playerId == player.id %}
                  {% set answered = true %}
                  {% set answerText = answer.text %}
                {% endif %}
              {% endfor %}
              {% if answered %}
                <td class="cell-preview" title="{{ answerText }}">{{ answerText | truncate(60) }}</td>
              {% else %}
                <td class="cell-empty">&mdash;</td>
              {% endif %}
            {% endfor %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="legend">
      <div class="legend__item">
        <span class="legend__swatch legend__swatch--completed"></span>
        <span>Answered</span>
      </div>
      <div class="legend__item">
        <span class="legend__swatch legend__swatch--empty"></span>
        <span>Unanswered</span>
      </div>
      <div class="legend__item">
        <span class="metadata">{{ players | length }} players &middot; {{ questions | length }} questions</span>
      </div>
    </div>
  </div>
</div>
{% endblock %}
