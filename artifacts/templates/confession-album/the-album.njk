{# the-album.njk — Saddle-stitched booklet, A5 portrait, 8–40 pages
   Data: { session, players[], questions[], answers[{playerId, questionId, text}], questionSet }
#}
{% extends "../_base.njk" %}
{% import "../_macros.njk" as m %}

{% set theme = "confession-album" %}
{% set title = "The Album — " + session.title %}

{% block extraStyles %}
{{ m.macroStyles() }}
<style>
  .cover {
    height: 210mm;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-color: var(--color-bg);
  }
  .cover__title {
    font-family: var(--ff-heading);
    font-size: var(--fs-3xl);
    color: var(--color-accent);
    margin-bottom: var(--sp-4);
  }
  .cover__subtitle {
    font-size: var(--fs-md);
    color: var(--color-muted);
    margin-bottom: var(--sp-8);
  }
  .cover__meta {
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    color: var(--color-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .toc {
    margin: var(--sp-6) 0;
  }
  .toc__item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--sp-2) 0;
    border-bottom: 1px dotted var(--color-divider);
  }
  .toc__question {
    font-family: var(--ff-body);
    font-size: var(--fs-sm);
    flex: 1;
  }
  .toc__page {
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    color: var(--color-muted);
    margin-left: var(--sp-4);
  }
  .question-spread {
    position: relative;
    padding-top: var(--sp-6);
  }
  .question-text {
    font-family: var(--ff-heading);
    font-size: var(--fs-lg);
    color: var(--color-accent);
    margin-bottom: var(--sp-6);
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--color-divider);
  }
  .answer-block {
    margin-bottom: var(--sp-6);
    padding-left: var(--sp-4);
    border-left: 2px solid var(--color-divider);
  }
  .answer-block__attribution {
    margin-top: var(--sp-2);
    text-align: right;
  }
  .colophon {
    text-align: center;
    padding-top: var(--sp-12);
    color: var(--color-muted);
  }
  .colophon__engine {
    font-size: var(--fs-xs);
    margin-top: var(--sp-6);
  }
</style>
{% endblock %}

{% block content %}
{# ── COVER ── #}
<div class="cover page--cover texture-parchment">
  <div style="position: relative; z-index: 2;">
    {{ m.ornament('fleuron') }}
    <h1 class="cover__title">The Confession Album</h1>
    <p class="cover__subtitle">{{ session.title }}</p>
    <p class="cover__meta">{{ session.date | dateFormat }}</p>
    <p class="cover__meta" style="margin-top: var(--sp-2);">
      Hosted by {{ session.host }} &middot; {{ session.location }}
    </p>
    {% if questionSet %}
      {{ m.eraBadge(questionSet) }}
    {% endif %}
  </div>
</div>

{# ── TABLE OF CONTENTS ── #}
<div class="page page-break texture-parchment texture-fiber">
  <div style="position: relative; z-index: 2;">
    {{ m.pageHeader('Table of Contents', null, players | length + ' players · ' + questions | length + ' questions') }}

    <div class="toc">
      {% for question in questions %}
      <div class="toc__item">
        <span class="toc__question">{{ loop.index }}. {{ question.text }}</span>
      </div>
      {% endfor %}
    </div>

    {{ m.divider('◆') }}

    <h3>Players</h3>
    {% for player in players %}
      {{ m.playerCard(player.name) }}
    {% endfor %}
  </div>
</div>

{# ── QUESTION SPREADS ── #}
{% for question in questions %}
<div class="page page-break question-spread texture-parchment texture-fiber">
  <div style="position: relative; z-index: 2;">
    {{ m.questionNumber(loop.index) }}

    <div class="question-text">
      {{ question.text }}
    </div>

    {% set questionAnswers = [] %}
    {% for answer in answers %}
      {% if answer.questionId == question.id %}
        {% set questionAnswers = (questionAnswers.push(answer), questionAnswers) %}
      {% endif %}
    {% endfor %}

    {% for answer in answers %}
      {% if answer.questionId == question.id %}
      <div class="answer-block avoid-break">
        <p class="drop-cap">{{ answer.text }}</p>
        <p class="answer-block__attribution">
          <span class="small-caps text-sm">
            {% for player in players %}
              {% if player.id == answer.playerId %}{{ player.name }}{% endif %}
            {% endfor %}
          </span>
        </p>
      </div>
      {% endif %}
    {% endfor %}

    {% if not loop.last %}
      {{ m.ornament('dots') }}
    {% endif %}
  </div>
</div>
{% endfor %}

{# ── COLOPHON ── #}
<div class="page page-break texture-parchment">
  <div class="colophon" style="position: relative; z-index: 2;">
    {{ m.ornament('fleuron') }}
    <p class="text-sm">This album was composed on {{ session.date | dateFormat }}</p>
    <p class="text-sm">at {{ session.location }}, hosted by {{ session.host }}.</p>
    <p class="text-sm" style="margin-top: var(--sp-4);">
      {{ players | length }} players answered {{ questions | length }} questions
      from the {{ questionSet | default('Classic') }} question set.
    </p>
    <p class="colophon__engine text-mono">
      Generated by Ephemera Engine &middot; parlor-games--ephemera-engine
    </p>
  </div>
</div>
{% endblock %}
